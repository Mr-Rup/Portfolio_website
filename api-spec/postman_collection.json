{
  "info": {
    "_postman_id": "c7a8b9d0-1234-5678-9abc-def012345678",
    "name": "Personal Portfolio & Admin Engine API",
    "description": "Ready-to-use Postman test suite demonstrating public endpoints and protected admin mutations (`/secure-control`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"your_password_here\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/api/projects",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "projects"]
            }
          }
        },
        {
          "name": "Create Project (Protected)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{JWT_TOKEN}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sample AI Dashboard\",\n  \"slug\": \"sample-ai-dashboard\",\n  \"description\": \"Real-time ML telemetry dashboard.\",\n  \"tech\": [\"React\", \"TypeScript\", \"Tailwind\"],\n  \"status\": \"Completed\",\n  \"icon\": \"FaChartBar\",\n  \"isShow\": true,\n  \"order\": 10\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/projects",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "projects"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:8000"
    },
    {
      "key": "JWT_TOKEN",
      "value": "paste_jwt_token_here"
    }
  ]
}
